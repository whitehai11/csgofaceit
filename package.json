{
  "name": "csgofaceit-mvp",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "assets:sync": "node scripts/sync-assets.mjs",
    "import:game-data": "tsx scripts/import-game-data.ts",
    "lint:security": "eslint \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "audit:deps": "npm audit --omit=dev",
    "audit:deps:ci": "node scripts/audit-ci.mjs",
    "test:security": "tsx --test apps/api/test/**/*.test.ts apps/server-manager/test/**/*.test.ts",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "overrides": {
    "@discordjs/rest": {
      "undici": "6.23.0"
    },
    "discord.js": {
      "undici": "6.23.0"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.24.0",
    "eslint-plugin-security": "^3.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
